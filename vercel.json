<script>
// Intersection Observer for section reveal
const sections = document.querySelectorAll('.section');
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });
sections.forEach(s => obs.observe(s));

// Loca tabs
const locas = [
  {
    icon: '🏚️', name: 'ROMA SLUMS', color: 'var(--neon)',
    desc: 'Стартовая локация. Узкие улочки, граффити, монстры среднего уровня. Идеальна для обучения механикам. Здесь спавнится Tung Tung Sahur и его братья-пеньки.',
    time: '3 МИН', monsters: '12+', lvl: '1–10', players: '∞'
  },
  {
    icon: '🏟️', name: 'COLOSSEO', color: 'var(--hot)',
    desc: 'Арена прошлого. Только PvP — монстров не ловишь, только сражаешься. 5 арен одновременно. Победитель поднимается в лидерборд Колизея. Шанс выпадения Legendary-монстра.',
    time: '3 МИН', monsters: '0', lvl: '10–25', players: '10'
  },
  {
    icon: '🌑', name: 'SICILIAN VOID', color: 'var(--purple)',
    desc: 'Тёмная зона. Доступна только ночью (22:00–06:00). Монстры сильнее и редкие, шанс Shiny x3. Опасно: проиграв PvP здесь, теряешь одного монстра из команды на 24ч.',
    time: '3 МИН', monsters: '8+', lvl: '15–30', players: '∞'
  },
  {
    icon: '🌊', name: 'VENICE SWAMP', color: '#00aaff',
    desc: 'Болотная Венеция. Только водные и тёмные монстры. Путь по карте разделён каналами — нужно искать мосты (реальные POI-точки). Уникальный монстр-эксклюзив — Gondoliero.',
    time: '3 МИН', monsters: '15+', lvl: '5–20', players: '∞'
  },
  {
    icon: '🍕', name: 'NAPOLI CHAOS', color: 'var(--gold)',
    desc: 'Хаотичная зона. Монстры спавнятся хаотично и быстро исчезают. Специальная механика: тут можно торговать монстрами с другими игроками напрямую в реальном времени.',
    time: '3 МИН', monsters: '20+', lvl: '1–40', players: '∞'
  }
];

function showLoca(i) {
  const l = locas[i];
  document.getElementById('locaBox').innerHTML = `
    <div class="loca-name" style="color:${l.color}">${l.icon} ${l.name}</div>
    <div class="loca-desc">${l.desc}</div>
    <div class="loca-stats">
      <div class="loca-stat"><div class="loca-stat-label">Время</div><div class="loca-stat-val" style="color:${l.color}">${l.time}</div></div>
      <div class="loca-stat"><div class="loca-stat-label">Монстры</div><div class="loca-stat-val" style="color:${l.color}">${l.monsters}</div></div>
      <div class="loca-stat"><div class="loca-stat-label">Уровень</div><div class="loca-stat-val" style="color:${l.color}">${l.lvl}</div></div>
      <div class="loca-stat"><div class="loca-stat-label">Игроки</div><div class="loca-stat-val" style="color:${l.color}">${l.players}</div></div>
    </div>
  `;
  document.querySelectorAll('.loca-tab').forEach((t, j) => {
    t.classList.toggle('active', i === j);
  });
}
</script>

